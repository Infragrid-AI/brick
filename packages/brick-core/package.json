{
  "name": "@brick/core",
  "version": "0.1.0",
  "description": "Brick DSL parser, compiler, and serializer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run grammar && tsc && cp src/grammar.js dist/grammar.js",
    "grammar": "peggy --format commonjs -o src/grammar.js src/grammar.peggy",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "peggy": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
