{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Brick",
  "scopeName": "source.brick",
  "patterns": [
    { "include": "#comment" },
    { "include": "#module_declaration" },
    { "include": "#type_definition" },
    { "include": "#enum_definition" },
    { "include": "#function_signature" },
    { "include": "#stmt_js_block" },
    { "include": "#stmt_py_block" },
    { "include": "#keyword_fn" },
    { "include": "#statement" },
    { "include": "#expression" }
  ],
  "repository": {

    "comment": {
      "name": "comment.line.double-slash.brick",
      "match": "//.*$"
    },

    "module_declaration": {
      "match": "\\b(module)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.module.brick" },
        "2": { "name": "entity.name.namespace.brick" }
      }
    },

    "type_definition": {
      "name": "meta.type.brick",
      "begin": "\\b(type)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.type.brick" },
        "2": { "name": "entity.name.type.brick" }
      },
      "patterns": [
        { "include": "#comment" },
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*(\\[\\])?)",
          "captures": {
            "1": { "name": "variable.other.property.brick" },
            "2": { "name": "entity.name.type.brick" }
          }
        }
      ]
    },

    "enum_definition": {
      "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(\"[^\"]*\"(?:\\s*\\|\\s*\"[^\"]*\")*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.brick" },
        "2": { "name": "entity.name.type.brick" },
        "3": { "name": "string.quoted.double.brick" }
      }
    },

    "function_signature": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)(?:\\s*(->)\\s*([A-Za-z_][A-Za-z0-9_]*(\\[\\])?))?",
      "captures": {
        "1": { "name": "keyword.declaration.function.brick storage.type.function.brick" },
        "2": { "name": "entity.name.function.brick" },
        "3": { "name": "meta.parameters.brick" },
        "4": { "name": "keyword.operator.arrow.brick" },
        "5": { "name": "entity.name.type.brick" }
      }
    },

    "keyword_fn": {
      "match": "\\b(fn)\\b",
      "name": "keyword.declaration.function.brick storage.type.function.brick"
    },

    "statement": {
      "patterns": [
        { "include": "#stmt_control_flow" },
        { "include": "#stmt_navigate" },
        { "include": "#stmt_click" },
        { "include": "#stmt_fill" },
        { "include": "#stmt_type" },
        { "include": "#stmt_select" },
        { "include": "#stmt_press" },
        { "include": "#stmt_wait" },
        { "include": "#stmt_scroll" },
        { "include": "#stmt_screenshot" },
        { "include": "#stmt_ai" },
        { "include": "#stmt_extract" },
        { "include": "#stmt_gen" },
        { "include": "#stmt_import" },
        { "include": "#stmt_read" },
        { "include": "#stmt_cookies" },
        { "include": "#stmt_load" },
        { "include": "#stmt_upload" },
        { "include": "#stmt_report" },
        { "include": "#stmt_return" },
        { "include": "#stmt_log_fail" },
        { "include": "#stmt_var_assign" },
        { "include": "#stmt_compound_assign" },
        { "include": "#stmt_arrow_assign" }
      ]
    },

    "stmt_control_flow": {
      "patterns": [
        {
          "match": "\\b(if|else|while|for|in|repeat|break|continue)\\b",
          "name": "keyword.control.flow.brick"
        },
        {
          "match": "\\b(not)\\b",
          "name": "keyword.operator.logical.brick"
        },
        {
          "include": "#stmt_operator_compare"
        }
      ]
    },

    "stmt_operator_compare": {
      "match": "(>=|<=|!=|==|>|<)",
      "name": "keyword.operator.comparison.brick"
    },

    "stmt_navigate": {
      "patterns": [
        {
          "match": "\\b(navigate)\\b",
          "name": "keyword.control.brick"
        },
        {
          "match": "\\b(go)\\s+(to)\\b",
          "captures": {
            "1": { "name": "keyword.control.brick" },
            "2": { "name": "keyword.control.brick" }
          }
        }
      ]
    },

    "stmt_click": {
      "match": "\\b(click)\\b(\\s+(as)\\b)?",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "3": { "name": "keyword.control.brick" }
      }
    },

    "stmt_fill": {
      "match": "\\b(fill)\\b.*\\b(with)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_type": {
      "match": "\\b(type)\\b.*\\b(with)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_select": {
      "match": "\\b(select)\\b.*\\b(to)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_press": {
      "match": "\\b(press)\\s+([A-Za-z0-9]+|\"[^\"]+\")",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "constant.other.key.brick" }
      }
    },

    "stmt_wait": {
      "match": "\\b(wait)\\s+([0-9]+(?:\\.[0-9]+)?)(ms|s|m)?\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "constant.numeric.brick" },
        "3": { "name": "keyword.other.unit.brick" }
      }
    },

    "stmt_scroll": {
      "match": "\\b(scroll)\\b.*\\b(by)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_screenshot": {
      "match": "\\b(screenshot)\\b",
      "name": "keyword.control.brick"
    },

    "stmt_ai": {
      "match": "\\b(ai)\\b",
      "name": "keyword.control.brick support.function.builtin.brick"
    },

    "stmt_extract": {
      "patterns": [
        {
          "match": "\\b(extract_table|extract_from)\\b",
          "name": "keyword.control.brick"
        },
        {
          "match": "\\b(extract)\\s+(table|from)\\b",
          "captures": {
            "1": { "name": "keyword.control.brick" },
            "2": { "name": "keyword.control.brick" }
          }
        }
      ]
    },

    "stmt_gen": {
      "patterns": [
        {
          "match": "\\b(gen_code|gen)\\b",
          "name": "keyword.control.brick support.function.builtin.brick"
        },
        {
          "match": "\\b(as|using)\\b",
          "name": "keyword.control.brick"
        }
      ]
    },

    "stmt_read": {
      "patterns": [
        {
          "match": "\\b(open_file|read_pdf_pages|read_pdf|read_gdoc|ocr)\\b",
          "name": "keyword.control.brick"
        }
      ]
    },

    "stmt_import": {
      "match": "\\b(import)\\b",
      "name": "keyword.control.import.brick"
    },

    "stmt_cookies": {
      "match": "\\b(set_cookies|load_excel_all)\\b",
      "name": "keyword.control.brick"
    },

    "stmt_load": {
      "patterns": [
        {
          "match": "\\b(load_sheet|load_excel)\\b",
          "name": "keyword.control.brick"
        },
        {
          "match": "\\b(load)\\s+(excel)\\b.*\\b(sheet)\\b",
          "captures": {
            "1": { "name": "keyword.control.brick" },
            "2": { "name": "keyword.control.brick" },
            "3": { "name": "keyword.control.brick" }
          }
        }
      ]
    },

    "stmt_upload": {
      "match": "\\b(upload)\\b.*\\b(to)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_report": {
      "match": "\\b(report)\\s+(title)\\b",
      "captures": {
        "1": { "name": "keyword.control.brick" },
        "2": { "name": "keyword.control.brick" }
      }
    },

    "stmt_return": {
      "match": "\\b(return)\\b",
      "name": "keyword.control.flow.brick"
    },

    "stmt_log_fail": {
      "match": "\\b(log|fail)\\b",
      "name": "support.function.builtin.brick"
    },

    "stmt_js_block": {
      "name": "meta.embedded.block.js.brick",
      "begin": "\\b(js)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.brick storage.type.language.brick" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        { "include": "source.js" }
      ]
    },

    "stmt_py_block": {
      "name": "meta.embedded.block.python.brick",
      "begin": "\\b(python)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.brick storage.type.language.brick" }
      },
      "contentName": "meta.embedded.block.python",
      "patterns": [
        { "include": "source.python" }
      ]
    },

    "stmt_var_assign": {
      "match": "(@[A-Za-z_][A-Za-z0-9_]*)\\s*=(?!=)",
      "captures": {
        "1": { "name": "variable.other.brick" }
      }
    },

    "stmt_compound_assign": {
      "match": "(@[A-Za-z_][A-Za-z0-9_]*)\\s*(\\+=|-=|\\*=|/=)",
      "captures": {
        "1": { "name": "variable.other.brick" },
        "2": { "name": "keyword.operator.assignment.compound.brick" }
      }
    },

    "stmt_arrow_assign": {
      "match": "(->)\\s*(@[A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.operator.arrow.brick" },
        "2": { "name": "variable.other.brick" }
      }
    },

    "expression": {
      "patterns": [
        { "include": "#variable" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#arrow" }
      ]
    },

    "variable": {
      "name": "variable.other.brick",
      "match": "@[A-Za-z_][A-Za-z0-9_]*"
    },

    "string": {
      "name": "string.quoted.double.brick",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.brick", "match": "\\\\." },
        { "name": "variable.other.brick", "match": "@[A-Za-z_][A-Za-z0-9_]*" }
      ]
    },

    "number": {
      "name": "constant.numeric.brick",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },

    "boolean": {
      "name": "constant.language.boolean.brick",
      "match": "\\b(true|false)\\b"
    },

    "null": {
      "name": "constant.language.null.brick",
      "match": "\\bnull\\b"
    },

    "arrow": {
      "name": "keyword.operator.arrow.brick",
      "match": "->"
    }
  }
}
